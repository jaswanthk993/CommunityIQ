# =========================================================================
# CommunityIQ AI - Python-First Architecture Environment Variables
# =========================================================================

# --- FastAPI Server & Production Config ---
NODE_ENV=production
LOG_LEVEL=INFO

# --- Google Gemini / Vertex AI credentials ---
# Generate your Google Gemini key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Cloud & Cloud Run Configuration ---
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_REGION=us-central1

# --- PostgreSQL Database with pgvector (AlloyDB / Cloud SQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:secure_password@localhost:5432/community_iq

# --- Vector Store & RAG Config (LlamaIndex) ---
LLAMA_INDEX_DB_NAME=community_iq
EMBEDDING_MODEL=text-embedding-004
LLM_MODEL=gemini-2.5-pro

# --- DuckDB / OLAP Path ---
ANALYTICS_DB_PATH=analytics_store.duckdb
